{
    "name": "serwersms/serwersmsbundle",
    "description": "Symfony 8.1 Bundle for communication with the API v2 SerwerSMS.pl",
    "type": "symfony-bundle",
    "keywords": ["serwersms", "api", "sms", "symfony"],
    "homepage": "https://serwersms.pl/",
    "authors": [
        {
            "name": "SerwerSMS.pl",
            "email": "biuro@serwersms.pl"
        }
    ],
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.4",
        "lib-curl": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "symfony/framework-bundle": "^8.0",
        "symfony/config": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "symfony/test-pack": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "SerwerSMS\\SerwerSMSBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SerwerSMS\\SerwerSMSBundle\\Tests\\": "tests/"
        }
    }
}
